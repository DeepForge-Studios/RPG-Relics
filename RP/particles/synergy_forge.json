{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "relics:synergy_forge",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": { "num_particles": 20 },
      "minecraft:emitter_lifetime_once": { "active_time": 0.05 },
      "minecraft:emitter_shape_sphere": {
        "offset": [0, 0.9, 0],
        "radius": 0.15,
        "direction": "outwards"
      },
      "minecraft:particle_initial_speed": "Math.random(2.5, 4.5)",
      "minecraft:particle_lifetime_expression": { "max_lifetime": "Math.random(0.25, 0.45)" },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, -5, 0],
        "linear_drag_coefficient": 1
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.1 * (1 - variable.particle_age / variable.particle_lifetime)",
          "0.1 * (1 - variable.particle_age / variable.particle_lifetime)"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": [0, 24],
          "uv_size": [8, 8]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "gradient": {
            "0.0": [0.95, 0.78, 0.35, 1],
            "1.0": [0.62, 0.28, 0.85, 0.5]
          },
          "interpolant": "variable.particle_age / variable.particle_lifetime"
        }
      },
      "minecraft:particle_appearance_lighting": {}
    }
  }
}
