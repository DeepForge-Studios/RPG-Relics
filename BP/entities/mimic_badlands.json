{
  "format_version": "1.21.60",
  "minecraft:entity": {
    "description": {
      "identifier": "relics:mimic_badlands",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "relics:sleep_mimic": {
        "minecraft:target_nearby_sensor": {
          "inside_range": 5,
          "outside_range": 10,
          "on_inside_range": {
            "event": "relics:awake_mimic"
          }
        },
        "minecraft:movement": {
          "value": 0
        }
      },
      "relics:awake_mimic": {
        "minecraft:ambient_sound_interval": {
          "event_name": "ambient",
          "value": 4,
          "range": 7
        },
        "minecraft:target_nearby_sensor": {
          "outside_range": 10,
          "on_outside_range": {
            "event": "relics:sleep_mimic"
          }
        },
        "minecraft:movement": {
          "value": 0.20
        },
        "minecraft:behavior.look_at_player": {
          "priority": 8,
          "look_distance": 6,
          "probability": 0.02
        },
        "minecraft:behavior.random_look_around": {
          "priority": 9
        },
        "minecraft:pushable": {
          "is_pushable": true,
          "is_pushable_by_piston": true
        },
        "minecraft:jump.static": {},
        "minecraft:annotation.break_door": {},
        "minecraft:behavior.hurt_by_target": {
          "priority": 1
        },
        "minecraft:behavior.melee_attack": {
          "priority": 3
        },
        "minecraft:navigation.walk": {
          "is_amphibious": true,
          "can_pass_doors": true,
          "can_walk": true,
          "can_break_doors": true
        },
        "minecraft:can_climb": {}
      }
    },
    "components": {
      "minecraft:movement.generic": {},
      "minecraft:nameable": {},
      "minecraft:experience_reward": {
        "on_death": "query.last_hit_by_player ? 5 : 0"
      },
      "minecraft:type_family": {
        "family": [
          "mimic",
          "monster",
          "mob"
        ]
      },
      "minecraft:collision_box": {
        "width": 1,
        "height": 1
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "must_see": true,
        "reselect_targets": true,
        "within_radius": 5,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "player"
                }
              ]
            },
            "max_dist": 16
          }
        ]
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_air": true,
        "breathes_water": true
      },
      "minecraft:attack": {
        "damage": 3
      },
      "minecraft:loot": {
        "table": "loot_tables/relics/entities/mimic.json"
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:physics": {},
      "minecraft:conditional_bandwidth_optimization": {}
    },
    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": [
            "relics:sleep_mimic"
          ]
        }
      },
      "relics:awake_mimic": {
        "remove": {
          "component_groups": [
            "relics:sleep_mimic"
          ]
        },
        "add": {
          "component_groups": [
            "relics:awake_mimic"
          ]
        }
      },
      "relics:sleep_mimic": {
        "remove": {
          "component_groups": [
            "relics:awake_mimic"
          ]
        },
        "add": {
          "component_groups": [
            "relics:sleep_mimic"
          ]
        }
      }
    }
  }
}
