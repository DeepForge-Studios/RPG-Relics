{
  "format_version": "1.13.0",
  "minecraft:feature_rules": {
    "description": {
      "identifier": "relics:relic_tower_mimic_surface",
      "places_feature": "relics:relic_tower_mimic_pool_feature"
    },
    "conditions": {
      "placement_pass": "after_surface_pass",
      "minecraft:biome_filter": {
        "test": "has_biome_tag",
        "operator": "==",
        "value": "overworld"
      }
    },
    "distribution": {
      "iterations": 1,
      "x": {
        "distribution": "uniform",
        "extent": [0, 15]
      },
      "y": "query.heightmap(variable.worldx, variable.worldz) - 1",
      "z": {
        "distribution": "uniform",
        "extent": [0, 15]
      },
      "scatter_chance": {
        "numerator": 1,
        "denominator": 28
      }
    }
  }
}
